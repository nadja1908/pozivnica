# Copy to `.env` next to package.json. Vite only exposes names starting with VITE_.

# Supabase Dashboard often shows Next.js names — here is the mapping:
#   NEXT_PUBLIC_SUPABASE_URL              → VITE_SUPABASE_URL
#   NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY  → VITE_SUPABASE_PUBLISHABLE_KEY  (or VITE_SUPABASE_ANON_KEY)

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Use ONE of these (same value from dashboard: publishable or legacy anon JWT):
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_YOUR_KEY_HERE
# VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Guest OTP for “Change RSVP” — 8+ random chars, keep secret.
VITE_GUEST_OTP_SECRET=replace_with_long_random_string

# Hosting: set the same VITE_* variables in Vercel / Netlify / Cloudflare, then rebuild.
